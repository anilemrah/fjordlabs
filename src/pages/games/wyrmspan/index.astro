---
import Base from "../../../layouts/Base.astro";
import ProductCard from "../../../components/ProductCard.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import { getProductsByGame } from "../../../data/products";
import { getGame } from "../../../data/games";

const game = getGame("wyrmspan")!;
const wyrmspanProducts = getProductsByGame("wyrmspan");

const articles = {
  rules: [
    {
      title: "Wyrmspan vs Wingspan: Key Rule Differences Explained",
      description: "Coming from Wingspan? Here's everything that works differently in Wyrmspan.",
      href: "/games/wyrmspan/wyrmspan-vs-wingspan-rules/",
    },
  ],
  strategy: [
    {
      title: "Wyrmspan Cave Strategy: How to Build an Efficient Dragon Engine",
      description: "Maximize your cave layout and chain dragon abilities for big combos.",
      href: "/games/wyrmspan/cave-strategy-guide/",
    },
  ],
  guides: [
    {
      title: "Is Wyrmspan Worth It? An Honest Review for Wingspan Fans",
      description: "If you love Wingspan, should you buy Wyrmspan? We break down the differences.",
      href: "/games/wyrmspan/is-wyrmspan-worth-it/",
    },
  ],
};
---

<Base
  title="Wyrmspan — Rules, Strategy & Accessories | Fjord Labs"
  description="Everything you need for Wyrmspan: rules clarifications, dragon-engine strategies, and premium 3D-printed resource tokens."
>
  <section class="py-16 md:py-20 px-6 bg-sand/50 border-b border-bark/5">
    <div class="max-w-4xl mx-auto">
      <nav class="flex items-center gap-2 text-sm text-bark/40 mb-6">
        <a href="/" class="hover:text-clay transition-colors">Home</a>
        <span>/</span>
        <span class="text-bark/60">Wyrmspan</span>
      </nav>

      <div class="flex flex-col sm:flex-row gap-6 items-start">
        <img src={game.image} alt={game.title} class="w-32 h-32 rounded-2xl object-cover border border-bark/10 shrink-0" />
        <div>
          <h1 class="text-3xl md:text-5xl font-heading font-bold text-bark mb-4 leading-tight">
            Wyrmspan
          </h1>
          <p class="text-lg text-bark/50 max-w-2xl leading-relaxed mb-6">
            {game.heroDescription}
          </p>

          <div class="flex flex-wrap gap-6 text-sm text-bark/40">
            <div><span class="font-semibold text-bark/60">Players:</span> {game.playerCount}</div>
            <div><span class="font-semibold text-bark/60">Play Time:</span> {game.playTime}</div>
            <div><span class="font-semibold text-bark/60">Complexity:</span> {game.complexity}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-bark mb-2">Rules Clarifications</h2>
      <p class="text-bark/40 mb-8">Wyrmspan rules that differ from Wingspan and common confusion points.</p>
      <div class="grid md:grid-cols-2 gap-6">
        {articles.rules.map((a) => (
          <ArticleCard title={a.title} description={a.description} href={a.href} category="Rules" />
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 px-6 bg-sand/30">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-bark mb-2">Strategy</h2>
      <p class="text-bark/40 mb-8">Master the dragon caves.</p>
      <div class="grid md:grid-cols-2 gap-6">
        {articles.strategy.map((a) => (
          <ArticleCard title={a.title} description={a.description} href={a.href} category="Strategy" />
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-bark mb-2">Guides & Reviews</h2>
      <p class="text-bark/40 mb-8">Is Wyrmspan for you? Buying advice and honest takes.</p>
      <div class="grid md:grid-cols-2 gap-6">
        {articles.guides.map((a) => (
          <ArticleCard title={a.title} description={a.description} href={a.href} category="Guide" />
        ))}
      </div>
    </div>
  </section>

  {wyrmspanProducts.length > 0 && (
    <section class="py-14 px-6 bg-sand/50 border-t border-bark/5">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-heading font-bold text-bark mb-2">Wyrmspan Accessories</h2>
        <p class="text-bark/40 mb-8">Premium 3D-printed resource tokens for your dragon adventures.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {wyrmspanProducts.map((product) => <ProductCard product={product} />)}
        </div>
      </div>
    </section>
  )}
</Base>
