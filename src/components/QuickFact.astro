---
interface Props {
  label: string;
  value: string;
  icon?: string;
}

const { label, value, icon = "📊" } = Astro.props;
---

<div class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg border border-bark/5 text-sm">
  <span>{icon}</span>
  <span class="text-bark/40">{label}</span>
  <span class="font-heading font-bold text-bark">{value}</span>
</div>
