---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="my-8">
  {title && <h3 class="text-lg font-heading font-bold text-bark mb-4">{title}</h3>}
  <div class="space-y-0 relative">
    <div class="absolute left-5 top-3 bottom-3 w-px bg-clay/20"></div>
    <slot />
  </div>
</div>
