---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="my-8 overflow-hidden rounded-xl border border-bark/10">
  {title && (
    <div class="px-5 py-3 bg-bark/[0.03] border-b border-bark/10">
      <h4 class="font-heading font-semibold text-sm text-bark">{title}</h4>
    </div>
  )}
  <div class="overflow-x-auto">
    <slot />
  </div>
</div>
