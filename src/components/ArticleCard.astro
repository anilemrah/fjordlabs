---
interface Props {
  title: string;
  description: string;
  href: string;
  category: string;
  game?: string;
}

const { title, description, href, category, game } = Astro.props;
---

<a
  href={href}
  class="group block p-6 bg-white rounded-2xl border border-bark/5 hover:border-clay/20 hover:shadow-lg hover:shadow-clay/5 transition-all duration-300"
>
  <div class="flex items-center gap-2 mb-3">
    <span
      class="px-2.5 py-0.5 bg-clay/10 text-clay text-[11px] font-semibold rounded-full uppercase tracking-wide"
    >
      {category}
    </span>
    {
      game && (
        <span class="px-2.5 py-0.5 bg-forest/10 text-forest text-[11px] font-semibold rounded-full">
          {game}
        </span>
      )
    }
  </div>
  <h3
    class="text-lg font-heading font-bold text-bark group-hover:text-clay transition-colors mb-2"
  >
    {title}
  </h3>
  <p class="text-sm text-bark/50 line-clamp-2">{description}</p>
  <span
    class="inline-flex items-center gap-1 mt-4 text-sm text-clay font-medium"
  >
    Read more
    <svg
      class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
  </span>
</a>
