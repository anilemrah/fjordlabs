---
interface Props {
  answer: string;
}

const { answer } = Astro.props;
---

<div class="my-8 p-6 bg-gradient-to-br from-clay/5 to-clay/10 rounded-2xl border border-clay/15">
  <div class="flex items-start gap-3">
    <span class="text-2xl shrink-0">🎯</span>
    <div>
      <span class="text-xs font-semibold text-clay uppercase tracking-wider">Quick Answer</span>
      <p class="text-lg font-heading font-bold text-bark mt-1 leading-snug">{answer}</p>
    </div>
  </div>
</div>
