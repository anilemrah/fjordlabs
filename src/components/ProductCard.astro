---
import type { Product } from "../data/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<a
  href={product.link}
  target="_blank"
  class="group block bg-white rounded-2xl overflow-hidden border border-bark/5 hover:border-clay/20 hover:shadow-lg hover:shadow-clay/5 transition-all duration-300"
>
  <div class="aspect-square overflow-hidden bg-sand">
    <img
      src={product.image}
      alt={product.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>
  <div class="p-5">
    <span
      class="text-[11px] font-semibold text-clay uppercase tracking-wider"
    >
      {product.type}
    </span>
    <h3
      class="text-lg font-heading font-bold text-bark mt-1 group-hover:text-clay transition-colors"
    >
      {product.title}
    </h3>
    <p class="text-sm text-bark/50 mt-2 line-clamp-2">{product.description}</p>
  </div>
</a>
